# --- Google Cloud ---
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=my-gcp-project-****          # e.g. agentic-ai-hackathon-rnd-****
GOOGLE_CLOUD_STORAGE_BUCKET=gs://my-bucket-****   # e.g. gs://agentic-ai-staging-****
GOOGLE_CLOUD_LOCATION=us-west1                     # e.g. us-central1, europe-west1
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=TRUE
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=TRUE

# --- Alteryx MCP Server (single endpoint, toolsets selected via feature flags below) ---
ALTERYX_MCP_URL=https://us1.alteryxcloud.com/mcp/mcp/v1
ALTERYX_MCP_TOKEN=eyJ0b2tlbiI6ICJYXXXXXXXXXXXXXXXXXXXXXXXX****  # Bearer token from Alteryx
ALTERYX_MCP_READ_ONLY=FALSE   # Optional: TRUE exposes only read-only tools (&readOnly=true)

# --- Workflow toolset (Alteryx Agentyx) ---
AGENTYX_ENABLED=FALSE

# --- Analytics toolset (Alteryx Auto Insights) ---
INSIGHTS_ENABLED=TRUE
